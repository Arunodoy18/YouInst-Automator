# ═══════════════════════════════════════════════════════════════
# YouInst AI — Engine (Workers) Dockerfile
# Includes: Python (TTS + Whisper), ffmpeg, Node.js
# ═══════════════════════════════════════════════════════════════

FROM node:20-bullseye AS base

# Install Python, ffmpeg, and build tools
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    ffmpeg \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip3 install --break-system-packages edge-tts openai-whisper

# Install Node.js dependencies
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# Copy engine source
COPY src/ ./src/
COPY tsconfig.json ./
COPY prisma/ ./prisma/
COPY prisma.config.ts ./

# Generate Prisma client
RUN npx prisma generate

# Create output directory
RUN mkdir -p output logs

# Env vars are injected via docker-compose env_file, NOT baked in
EXPOSE 6379

CMD ["npx", "ts-node", "src/workers/index.ts"]
