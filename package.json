{
  "name": "youinst-automator",
  "version": "1.0.0",
  "description": "AI Shorts Automation Engine — Generate, render, and upload YouTube Shorts from a single CLI command.",
  "private": true,
  "scripts": {
    "generate": "ts-node src/cli/generate.ts",
    "pipeline": "ts-node src/lib/orchestrator.ts",
    "workers": "ts-node src/workers/index.ts",
    "webapp": "cd webapp && npm run dev",
    "webapp:build": "cd webapp && npm run build",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@remotion/bundler": "4.0.263",
    "@remotion/cli": "4.0.263",
    "@remotion/renderer": "4.0.263",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.69.2",
    "dotenv": "^16.4.7",
    "edge-tts": "^1.0.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "groq-sdk": "^0.8.0",
    "ioredis": "^5.9.3",
    "node-cron": "^4.2.1",
    "pexels": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "prisma": "^7.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
