{
  "name": "youinst-automator",
  "version": "1.0.0",
  "description": "AI Shorts Automation Engine — Generate, render, and upload YouTube Shorts from a single CLI command.",
  "private": true,
  "scripts": {
    "generate": "ts-node src/cli/generate.ts generate",
    "pipeline": "ts-node src/lib/orchestrator.ts",
    "cli": "ts-node src/cli/generate.ts",
    "status": "ts-node src/cli/generate.ts status",
    "workers": "ts-node src/workers/index.ts",
    "webapp": "cd webapp && npm run dev",
    "webapp:build": "cd webapp && npm run build",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "voice:train-raju": "ts-node src/cli/clone-voice.ts train input/Raju.mp4 --name raju_cloned --lang hindi",
    "voice:list": "ts-node src/cli/clone-voice.ts list",
    "voice:test-raju": "ts-node src/cli/clone-voice.ts test raju_cloned \"Bhai, aaj main tumhe ek aisi baat bataunga jo tumhari zindagi badal degi!\"",
    "voice:analyze-raju": "ts-node src/cli/clone-voice.ts analyze input/Raju.mp4",
    "voice:test": "ts-node src/cli/generate.ts test-tts",
    "voice:add-elevenlabs": "ts-node scripts/add-elevenlabs-voice.ts",
    "video:quick": "ts-node src/cli/generate.ts generate --niche tech",
    "video:help": "ts-node src/cli/generate.ts help",
    "verify": "ts-node scripts/verify-system.ts"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@remotion/bundler": "4.0.263",
    "@remotion/cli": "4.0.263",
    "@remotion/renderer": "4.0.263",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.69.2",
    "dotenv": "^16.4.7",
    "edge-tts": "^1.0.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "groq-sdk": "^0.8.0",
    "ioredis": "^5.9.3",
    "node-cron": "^4.2.1",
    "pexels": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "prisma": "^7.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
