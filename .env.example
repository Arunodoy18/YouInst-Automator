# ═══════════════════════════════════════════════════════════════
# YouInst AI — Environment Variables
# 
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your API keys below
#   3. Never commit .env to git (already in .gitignore)
# ═══════════════════════════════════════════════════════════════

# ── AI Provider (REQUIRED) ───────────────────────────────────
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here

# ── Open Source AI Tools (Video Generation) ──────────────────
# VoiceBox (Meta TTS) - Local installation, no API key needed
# Install: pip install metavoice
VOICEBOX_MODEL_PATH=./models/voicebox

# Golpo AI (Story-based video generation)
# Get API key at: https://golpo.ai/signup
GOLPO_API_KEY=
GOLPO_API_URL=https://api.golpo.ai/v1

# bobaAnime (Anime-style video generation)
# Get API key at: https://boba-anime.com/signup
BOBA_ANIME_API_KEY=
BOBA_ANIME_API_URL=https://api.boba-anime.com/v1

# Reroll (Video enhancement & upscaling)
# Get API key at: https://reroll.ai/signup
REROLL_API_KEY=
REROLL_API_URL=https://api.reroll.ai/v1

# ── YouTube OAuth2 (Optional — required for YouTube uploads) ─
# Setup: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Instagram Graph API (Optional — required for Instagram uploads) ─
# Setup: https://developers.facebook.com/apps/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── Background Media (Optional — improves video quality) ──────
# Pexels: https://www.pexels.com/api/
# Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── ElevenLabs (Voice Cloning & TTS) ──────────────────────────
# Get API key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── Deepgram (Audio Transcription) ────────────────────────────
# Get API key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ── SERP API (Web Search & Data Scraping) ─────────────────────
# Get API key at: https://serpapi.com/manage-api-key
SERP_API_KEY=

# ── Pinecone (Vector Database for RAG & Semantic Search) ──
# Get API key at: https://app.pinecone.io/
PINECONE_API_KEY=

# ── NextAuth (REQUIRED for webapp authentication) ────────────
# Generate secret: openssl rand -base64 48
NEXTAUTH_SECRET=change-this-to-a-random-64-char-string-in-production
NEXTAUTH_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Local: file:./prisma/youinst.db
# Docker: file:/app/data/youinst.db
DATABASE_URL=file:./prisma/youinst.db

# ═══════════════════════════════════════════════════════════════
# Execution Modes:
#
# DEV (no Redis):
#   Dashboard → API → runFullPipeline() directly (fire-and-forget)
#   CLI: npx ts-node src/cli/generate.ts generate ai
#
# PRODUCTION (with Redis):
#   Dashboard → API → BullMQ queue → Workers → runFullPipeline()
#   Start workers: npx ts-node src/workers/index.ts
#   Start webapp:  cd webapp && npm run dev
#   Or use Docker: docker-compose up
# ═══════════════════════════════════════════════════════════════