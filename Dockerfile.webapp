# ═══════════════════════════════════════════════════════════════
# YouInst AI — Webapp (Next.js) Dockerfile
# Multi-stage build: deps → builder → production runner
# ═══════════════════════════════════════════════════════════════

FROM node:20-alpine AS base

# ── Stage 1: Install dependencies ────────────────────────────
FROM base AS deps
WORKDIR /app

# Root package (engine deps needed at build time for API route imports)
COPY package.json package-lock.json ./
RUN npm ci

# Webapp package
COPY webapp/package.json webapp/package-lock.json ./webapp/
WORKDIR /app/webapp
RUN npm ci

# ── Stage 2: Build ───────────────────────────────────────────
FROM base AS builder
WORKDIR /app

# Copy all deps
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/webapp/node_modules ./webapp/node_modules

# Copy source (engine + webapp + Prisma)
COPY src/ ./src/
COPY webapp/ ./webapp/
COPY prisma/ ./prisma/
COPY prisma.config.ts ./
COPY package.json ./
COPY tsconfig.json ./

# Generate Prisma client
RUN npx prisma generate

# Build Next.js (standalone mode)
WORKDIR /app/webapp
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ── Stage 3: Production runner ───────────────────────────────
FROM base AS runner
WORKDIR /app

# Install Python + ffmpeg for engine pipeline (API routes import engine code)
RUN apk add --no-cache python3 py3-pip ffmpeg bash \
    && pip3 install --break-system-packages edge-tts openai-whisper

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy standalone Next.js output
COPY --from=builder /app/webapp/.next/standalone ./
COPY --from=builder /app/webapp/.next/static ./webapp/.next/static
COPY --from=builder /app/webapp/public ./webapp/public

# Copy Prisma schema + generated client
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/prisma.config.ts ./

# Copy engine source (needed by API routes at runtime)
COPY --from=builder /app/src ./src
COPY --from=builder /app/node_modules ./node_modules

# Create output/logs dirs
RUN mkdir -p output logs && chown -R nextjs:nodejs output logs

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "webapp/server.js"]
